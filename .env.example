# LLM Configuration
ECOM_LLM_API_KEY=your_api_key_here
ECOM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ECOM_LLM_MODEL=qwen-plus
ECOM_DATA_GENERATION_MODEL=qwen-plus
ECOM_DATA_GENERATION_PRODUCT_COUNT=30
ECOM_DATA_GENERATION_USER_COUNT=8
ECOM_DATA_GENERATION_BEHAVIORS_PER_USER=8
ECOM_DATA_GENERATION_CATEGORIES=耳机,手机,配件,户外电源,户外,个护,电脑,平板
ECOM_DATA_GENERATION_MAX_TOKENS=8192
ECOM_DATA_GENERATION_BATCH_SIZE=10
ECOM_DATA_GENERATION_RESET_TABLES=true
ECOM_DATA_GENERATION_RESET_VECTORS=true

# Embedding Configuration
ECOM_EMBEDDING_API_KEY=
ECOM_EMBEDDING_BASE_URL=
ECOM_EMBEDDING_MODEL=text-embedding-v4
ECOM_EMBEDDING_DIMENSION=1024

# Redis
ECOM_REDIS_URL=redis://localhost:6379/0

# Milvus
ECOM_MILVUS_HOST=localhost
ECOM_MILVUS_PORT=19530

# Database
ECOM_DATABASE_URL=sqlite:///./ecommerce.db

# A/B Testing
ECOM_AB_TEST_ENABLED=true
